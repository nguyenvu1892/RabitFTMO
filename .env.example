# ============================================================
# .env.example — Template cấu hình môi trường Rabit_FTMO
# ============================================================
# HƯỚNG DẪN:
#   1. Copy file này thành file ".env" (đúng tên, không có phần mở rộng .example)
#   2. Điền giá trị thật của bạn vào bên dưới
#   3. TUYỆT ĐỐI không commit file .env lên Git
# ============================================================

# --- Thông tin đăng nhập MetaTrader 5 ---
MT5_LOGIN=YOUR_ACCOUNT_NUMBER_HERE
MT5_PASSWORD=YOUR_PASSWORD_HERE
MT5_SERVER=YOUR_BROKER_SERVER_HERE

# Ví dụ FTMO:
# MT5_LOGIN=12345678
# MT5_PASSWORD=MySecurePass123
# MT5_SERVER=FTMO-Demo2

# --- Cấu hình Symbol ---
SYMBOL=XAGUSD

# --- Cấu hình Rủi ro ---
RISK_PER_TRADE=0.005       # 0.5% rủi ro mỗi lệnh
MAX_DAILY_DRAWDOWN=0.045   # 4.5% Hard-Stop FTMO

# --- API Lịch kinh tế (cho News Filter - Phase 2) ---
# NEWS_API_KEY=YOUR_API_KEY_HERE
# NEWS_API_URL=https://nfs.faireconomy.media/ff_calendar_thisweek.json
